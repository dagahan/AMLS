COMPOSE_PROJECT_NAME=amls-service
DOCKER_CONTAINERS_RESTART=no
TZ=UTC
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=securepassword123
POSTGRES_DB=amls_db
VALKEY_HOST=127.0.0.1
VALKEY_PORT=6379
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=3
SESSIONS_MAX_LIFE_DAYS=90
SESSIONS_INACTIVE_DAYS=30
JWT_PRIVATE_KEY_PATH=backend/certs/jwt-private.pem
JWT_PUBLIC_KEY_PATH=backend/certs/jwt-public.pem
DB_ECHO=0
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
ENTRANCE_ASSESSMENT_I_DONT_KNOW_SCALAR=1.4
ENTRANCE_ASSESSMENT_ANCESTOR_SUPPORT_CORRECT=0.85
ENTRANCE_ASSESSMENT_ANCESTOR_SUPPORT_WRONG=0.12
ENTRANCE_ASSESSMENT_DESCENDANT_SUPPORT_CORRECT=0.25
ENTRANCE_ASSESSMENT_DESCENDANT_SUPPORT_WRONG=0.90
ENTRANCE_ASSESSMENT_ANCESTOR_DECAY=0.70
ENTRANCE_ASSESSMENT_DESCENDANT_DECAY=0.90
ENTRANCE_ASSESSMENT_BRANCH_PENALTY_EXPONENT=1.0
ENTRANCE_ASSESSMENT_TEMPERATURE_SHARPENING=1.5
ENTRANCE_ASSESSMENT_ENTROPY_STOP=0.90
ENTRANCE_ASSESSMENT_UTILITY_STOP=0.18
ENTRANCE_ASSESSMENT_LEADER_PROBABILITY_STOP=0.80
ENTRANCE_ASSESSMENT_MAX_QUESTIONS=16
ENTRANCE_ASSESSMENT_EPSILON=0.000000001

S3_BUCKET_NAME=amls
S3_ENDPOINT_URL=https://s3.ru-7.storage.selcloud.ru
S3_PUBLIC_BASE_URL=https://s3.ru-7.storage.selcloud.ru/amls
S3_ACCESS_KEY=your_access_key
S3_SECRET_KEY=your_secret_key
S3_REGION=ru-7
S3_TLS_VERIFY=1
