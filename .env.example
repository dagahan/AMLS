LMS_AUTO_WAKE_RETRY_COUNT=2
ENTRANCE_ASSESSMENT_I_DONT_KNOW_SCALAR=1.4
ENTRANCE_ASSESSMENT_ANCESTOR_SUPPORT_CORRECT=0.85
ENTRANCE_ASSESSMENT_ANCESTOR_SUPPORT_WRONG=0.12
ENTRANCE_ASSESSMENT_DESCENDANT_SUPPORT_CORRECT=0.25
ENTRANCE_ASSESSMENT_DESCENDANT_SUPPORT_WRONG=0.90
ENTRANCE_ASSESSMENT_ANCESTOR_DECAY=0.70
ENTRANCE_ASSESSMENT_DESCENDANT_DECAY=0.90
ENTRANCE_ASSESSMENT_BRANCH_PENALTY_EXPONENT=1.0
ENTRANCE_ASSESSMENT_TEMPERATURE_SHARPENING=1.5
