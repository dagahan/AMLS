ENTRANCE_ASSESSMENT_UTILITY_STOP=0.18
ENTRANCE_ASSESSMENT_LEADER_PROBABILITY_STOP=0.80
ENTRANCE_ASSESSMENT_MAX_QUESTIONS=25
ENTRANCE_ASSESSMENT_EPSILON=0.000000001
ENTRANCE_ASSESSMENT_MAX_EXACT_STATES=100000

S3_BUCKET_NAME=amls
