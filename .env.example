VALKEY_PORT=6379
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=3
SESSIONS_MAX_LIFE_DAYS=90
SESSIONS_INACTIVE_DAYS=30
JWT_PRIVATE_KEY_PATH=backend/certs/jwt-private.pem
JWT_PUBLIC_KEY_PATH=backend/certs/jwt-public.pem
DB_ECHO=0
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
LMS_BASE_URL=http://nikiausovs-macbook-pro.tail89767d.ts.net:1234/v1
LMS_API_KEY=lm-studio
LMS_MODEL=qwen2.5-coder-3b-instruct-mlx
LMS_TIMEOUT_SECONDS=30
LMS_AUTO_WAKE_ENABLED=1
