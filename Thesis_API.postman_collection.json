    },
    {
      "name": "Admin Problems",
      "item": [
        {
          "name": "Create Problem",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{admin_access_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"subtopic_id\": \"{{subtopic_id}}\",\n  \"difficulty_id\": \"{{difficulty_id}}\",\n  \"condition\": \"If x^2 = 16 and x > 0, find x.\",\n  \"solution\": \"Because x > 0, from x^2 = 16 we get x = 4.\",\n  \"condition_images\": [],\n  \"solution_images\": [],\n  \"answer_options\": [\n    {\n      \"text\": \"-4\",\n      \"is_correct\": false\n    },\n    {\n      \"text\": \"4\",\n      \"is_correct\": true\n    },\n    {\n      \"text\": \"8\",\n      \"is_correct\": false\n    }\n  ],\n  \"subskills\": [\n    {\n      \"subskill_id\": \"{{subskill_id_1}}\",\n      \"weight\": 0.6\n    },\n    {\n      \"subskill_id\": \"{{subskill_id_2}}\",\n      \"weight\": 0.4\n    }\n  ]\n}"
            },
            "url": "{{base_url}}/admin/problems"
          }
        },
        {
          "name": "List Admin Problems",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{admin_access_token}}"
              }
            ],
            "url": "{{base_url}}/admin/problems?topic_id={{topic_id}}&subtopic_id={{subtopic_id}}&difficulty_id={{difficulty_id}}&subskill_id={{subskill_id_1}}"
          }
        },
        {
          "name": "Get Admin Problem",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{admin_access_token}}"
              }
            ],
            "url": "{{base_url}}/admin/problems/{{problem_id}}"
          }
        },
        {
          "name": "Update Problem",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{admin_access_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"condition\": \"If x^2 = 25 and x > 0, find x.\",\n  \"solution\": \"Because x > 0, from x^2 = 25 we get x = 5.\"\n}"
            },
            "url": "{{base_url}}/admin/problems/{{problem_id}}"
          }
        },
        {
          "name": "Delete Problem",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{admin_access_token}}"
              }
            ],
            "url": "{{base_url}}/admin/problems/{{problem_id}}"
          }
        }
