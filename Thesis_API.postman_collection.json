{
  "info": {
    "_postman_id": "3d5d8c9f-6e49-4aa5-b31d-3c24d59dbb15",
    "name": "Thesis API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register Student",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{student_email}}\",\n  \"first_name\": \"Student\",\n  \"last_name\": \"User\",\n  \"password\": \"{{student_password}}\",\n  \"avatar_url\": null\n}"
            },
            "url": "{{base_url}}/auth/register"
          }
        },
        {
          "name": "Login Student",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const data = pm.response.json();",
                  "pm.environment.set('student_access_token', data.access_token);",
                  "pm.environment.set('student_refresh_token', data.refresh_token);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{student_email}}\",\n  \"password\": \"{{student_password}}\"\n}"
            },
            "url": "{{base_url}}/auth/login"
          }
        },
        {
          "name": "Login Admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const data = pm.response.json();",
                  "pm.environment.set('admin_access_token', data.access_token);",
                  "pm.environment.set('admin_refresh_token', data.refresh_token);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{admin_email}}\",\n  \"password\": \"{{admin_password}}\"\n}"
            },
            "url": "{{base_url}}/auth/login"
          }
        },
        {
          "name": "Refresh Student Tokens",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh_token\": \"{{student_refresh_token}}\"\n}"
            },
            "url": "{{base_url}}/auth/refresh"
          }
        },
        {
          "name": "Get Current User",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{student_access_token}}"
              }
            ],
            "url": "{{base_url}}/auth/me"
          }
        }
      ]
    },
    {
      "name": "Public Catalog",
      "item": [
        {
          "name": "List Topics",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/topics"
          }
        },
        {
          "name": "List Subtopics",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/subtopics?topic_id={{topic_id}}"
          }
        },
        {
          "name": "List Skills",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/skills"
          }
        },
        {
          "name": "List Subskills",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/subskills?skill_id={{skill_id}}"
          }
        },
        {
          "name": "List Difficulties",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/difficulties"
          }
        }
      ]
    },
    {
      "name": "Public Problems",
      "item": [
        {
          "name": "List Problems",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/problems?topic_id={{topic_id}}&subtopic_id={{subtopic_id}}&difficulty_id={{difficulty_id}}&subskill_id={{subskill_id_1}}"
          }
        },
        {
          "name": "Get Problem",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/problems/{{problem_id}}"
          }
        }
      ]
    },
    {
      "name": "Student",
      "item": [
        {
          "name": "Get Progress",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{student_access_token}}"
              }
            ],
            "url": "{{base_url}}/student/progress"
          }
        },
        {
          "name": "Submit Problem",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{student_access_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"answer_option_id\": \"{{answer_option_id}}\"\n}"
            },
            "url": "{{base_url}}/student/problems/{{problem_id}}/submit"
          }
        }
      ]
    },
